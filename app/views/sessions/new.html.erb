<header id="content-header">
  <h1>Sign In</h1>
</header>

<%= form_tag(session_path) do %>
  <fieldset>
    <ol>
      <li class="required">
        <%= label_tag :email_or_username, "Email or Username", required: true %>
        <%= text_field_tag :email_or_username, nil, autofocus: true, size: 40 %>
      </li>
      <li class="required">
        <%= label_tag :password, nil, required: true %>
        <%= password_field_tag :password, nil, size: 40 %>
      </li>
    </ol>
    <p>
      <%= submit_tag 'Sign In' %>
    </p>
    <p>
      Not a member? <%= link_to "Sign Up!", signup_path %>
    </p>
  </fieldset>
<% end %>